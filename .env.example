# Frontend environment variables (Vite)
# Backend variables (PostgreSQL/Prisma/Redis/JWT) are in backend/.env.example

# API Configuration
VITE_API_URL=http://localhost:5000/api

# EMI Calculator API (RapidAPI)
VITE_RAPIDAPI_KEY=your_rapidapi_key_here
VITE_RAPIDAPI_HOST=your_rapidapi_host_here

# Google Apps Script URL for form submissions
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your_script_id_here/exec
