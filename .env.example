# Frontend environment variables (Vite)
# Backend variables (PostgreSQL/Prisma/Redis/JWT) are in backend/.env.example

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Docker backend override. Set this in the root .env when the backend container
# should connect to an existing host Postgres instance instead of compose db.
# Example:
# DATABASE_URL_DOCKER=postgresql://user:password@host.docker.internal:5432/dbname?schema=public
DATABASE_URL_DOCKER=

# Docker Vault overrides. These are used by the compose backend containers so
# they do not inherit localhost-based values from backend/.env.
VAULT_ADDR_DOCKER=http://vault:8200
VAULT_TOKEN_DOCKER=dev-only-root-token
VAULT_TRANSIT_PATH_DOCKER=transit
VAULT_GPS_INDIA_KEY_DOCKER=gps-india-internal
VAULT_NAMESPACE_DOCKER=

# Google Apps Script URL for form submissions
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your_script_id_here/exec
