# Server Configuration
PORT=5000
NODE_ENV=development

# ============================================================================
# PostgreSQL (Prisma) - REQUIRED
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public
PG_POOL_MAX=5
PG_POOL_MIN=2
# In production, TLS is enabled by default (rejectUnauthorized: true).
# Set DB_SSL=false only when the DB server enforces SSL itself via sslmode in the connection string,
# or when connecting via a local Unix socket / Docker-internal network where TLS is unnecessary.
# DB_SSL=false


# ============================================================================
# JWT Configuration - REQUIRED
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-must-differ-from-jwt-secret

# Frontend URL(s) for CORS
# Comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis Configuration
# Required in production for token blacklist persistence and distributed rate limits.
# Example local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
# Maximum memory Redis may use. redis.conf sets maxmemory-policy=volatile-lru so only
# keys with a TTL (cache, OTPs, blacklisted tokens) are evicted — never permanent keys.
# Dev: 256mb  |  Staging: 512mb  |  Production: 512mb–1gb (monitor and tune)
REDIS_MAXMEMORY=256mb

# Field-level encryption (base64 32-byte key)
FIELD_ENCRYPTION_KEY=
# HMAC key used for hashing emails in audit logs (32+ random chars)
EMAIL_HASH_KEY=

# System partner (used for public website leads)
SYSTEM_PARTNER_ID=

# ============================================================================
# Email Configuration (optional)
# ============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# FROM_EMAIL=noreply@example.com

# ============================================================================
# SMS Configuration
# ============================================================================
# MSG91 (OTP SMS)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID= # org-specific sender ID from MSG91; do not use shared defaults

# Alternative: Twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

