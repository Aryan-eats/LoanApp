generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                     String            @id @default(uuid()) @db.Uuid
  email                  String            @unique
  password               String?
  firstName              String            @map("first_name")
  lastName               String            @map("last_name")
  phone                  String?
  role                   UserRole          @default(partner)
  isActive               Boolean           @default(true) @map("is_active")
  isEmailVerified        Boolean           @default(false) @map("is_email_verified")
  isPhoneVerified        Boolean           @default(false) @map("is_phone_verified")
  lastLogin              DateTime?         @map("last_login")
  resetPasswordToken     String?           @map("reset_password_token")
  resetPasswordExpires   DateTime?         @map("reset_password_expires")
  otpHash                 String?           @map("otp")
  otpExpires             DateTime?         @map("otp_expires")
  failedLoginAttempts    Int               @default(0) @map("failed_login_attempts")
  lockUntil              DateTime?         @map("lock_until")
  refreshToken           String?           @map("refresh_token")
  refreshTokenExpires    DateTime?         @map("refresh_token_expires")
  partnerType            PartnerType?      @map("partner_type")
  city                   String?
  state                  String?
  pincode                String?
  aadhaarNumber          String?           @map("aadhaar_number")
  businessName           String?           @map("business_name")
  businessAddress        String?           @map("business_address")
  yearsInOperation       String?           @map("years_in_operation")
  panNumber              String?           @map("pan_number")
  gstNumber              String?           @map("gst_number")
  hasExperience          String?           @map("has_experience")
  expectedLeads          String?           @map("expected_leads")
  accountHolderName      String?           @map("account_holder_name")
  bankName               String?           @map("bank_name")
  accountNumber          String?           @map("account_number")
  ifscCode               String?           @map("ifsc_code")
  upiId                  String?           @map("upi_id")
  encryptionVersion      Int               @default(0) @map("encryption_version")
  consentDataShare       Boolean           @default(false) @map("consent_data_share")
  consentCommission      Boolean           @default(false) @map("consent_commission")
  declarationNotEmployed Boolean           @default(false) @map("declaration_not_employed")
  consentPrivacyPolicy   Boolean           @default(false) @map("consent_privacy_policy")
  onboardingStatus       OnboardingStatus? @default(pending) @map("onboarding_status")
  onboardingCompletedAt  DateTime?         @map("onboarding_completed_at")
  kycStatus              KycStatus?        @default(pending) @map("kyc_status")
  kycRejectionReason     String?           @map("kyc_rejection_reason")
  internalNotes          String?           @map("internal_notes")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  activeSessions         ActiveSession[]
  auditLogs              AuditLog[]
  leads                  Lead[]
  partnerData            PartnerData[]
  passwordHistory        PasswordHistory[]
  ownedPartners          Partner[]         @relation("PartnerOwner")
  partnerMemberships     PartnerUser[]
  consentGrantsSubmitted ConsentGrant[]    @relation("ConsentGrantSubmittedBy")
  submissionEventsChanged SubmissionEvent[] @relation("SubmissionEventChangedBy")

  @@index([role])
  @@index([phone])
  @@map("users")
}

model PasswordHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  hash      String
  changedAt DateTime @default(now()) @map("changed_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, changedAt])
  @@map("password_history")
}

model ActiveSession {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  deviceFingerprint String   @map("device_fingerprint")
  lastActive        DateTime @default(now()) @map("last_active")
  userAgent         String?  @map("user_agent")
  ip                String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprint])
  @@index([userId])
  @@index([deviceFingerprint])
  @@map("active_sessions")
}

model Partner {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  partnerType      String            @default("freelancer") @map("partner_type")
  status           String            @default("active")
  ownerUserId      String            @map("owner_user_id") @db.Uuid
  contactEmail     String?           @map("contact_email")
  contactPhone     String?           @map("contact_phone")
  city             String?
  state            String?
  pincode          String?
  businessName     String?           @map("business_name")
  gstNumber        String?           @map("gst_number")
  panNumber        String?           @map("pan_number")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  owner            User              @relation("PartnerOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members          PartnerUser[]
  partnerData      PartnerData[]
  leads            Lead[]
  consentGrants    ConsentGrant[]
  submissionEvents SubmissionEvent[]

  @@index([ownerUserId])
  @@index([status])
  @@map("partners")
}

model PartnerUser {
  id        String   @id @default(uuid()) @db.Uuid
  partnerId String   @map("partner_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("admin")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partnerId, userId])
  @@index([partnerId])
  @@index([userId])
  @@map("partner_users")
}

model SubmissionEvent {
  id            String   @id @default(uuid()) @db.Uuid
  leadId        String   @map("lead_id") @db.Uuid
  partnerOrgId  String?  @map("partner_org_id") @db.Uuid
  oldStatus     String?  @map("old_status")
  newStatus     String   @map("new_status")
  changedBy     String?  @map("changed_by") @db.Uuid
  changeSource  String   @default("manual") @map("change_source")
  note          String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  partnerOrg    Partner? @relation(fields: [partnerOrgId], references: [id], onDelete: SetNull)
  changedByUser User?    @relation("SubmissionEventChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([partnerOrgId])
  @@map("submission_events")
}

model Lead {
  id                     String            @id @default(uuid()) @db.Uuid
  clientFullName         String            @map("client_full_name")
  clientPhone            String            @map("client_phone")
  clientEmail            String?           @map("client_email")
  clientDateOfBirth      String?           @map("client_date_of_birth")
  clientPanNumber        String?           @map("client_pan_number")
  clientAadhaar          String?           @map("client_aadhaar")
  clientEmployment       EmploymentType?   @map("client_employment")
  clientIncome           Decimal?          @map("client_income") @db.Decimal(15, 2)
  clientCompany          String?           @map("client_company")
  clientExperience       Int?              @map("client_experience")
  clientCity             String?           @map("client_city")
  clientPincode          String?           @map("client_pincode")
  loanType               String            @map("loan_type")
  loanAmount             Decimal           @map("loan_amount") @db.Decimal(15, 2)
  tenure                 Int?
  sanctionedAmount       Decimal?          @map("sanctioned_amount") @db.Decimal(15, 2)
  disbursedAmount        Decimal?          @map("disbursed_amount") @db.Decimal(15, 2)
  interestRate           Decimal?          @map("interest_rate") @db.Decimal(5, 2)
  emi                    Decimal?          @db.Decimal(15, 2)
  status                 LeadStatus        @default(submitted)
  bankAssigned           String?           @map("bank_assigned")
  bankCode               String?           @map("bank_code")
  bankLogo               String?           @map("bank_logo")
  preferredBank          String?           @map("preferred_bank")
  partnerId              String?           @map("partner_id") @db.Uuid
  partnerName            String            @map("partner_name")
  partnerOrgId           String?           @map("partner_org_id") @db.Uuid
  sourcePartnerDataId    String?           @map("source_partner_data_id") @db.Uuid
  encryptionVersion      Int               @default(0) @map("encryption_version")
  isEligible             Boolean?          @map("is_eligible")
  maxLoanAmount          Decimal?          @map("max_loan_amount") @db.Decimal(15, 2)
  minLoanAmount          Decimal?          @map("min_loan_amount") @db.Decimal(15, 2)
  estimatedEMI           Decimal?          @map("estimated_emi") @db.Decimal(15, 2)
  eligibilityCheckedAt   DateTime?         @map("eligibility_checked_at")
  commissionAmount       Decimal?          @map("commission_amount") @db.Decimal(15, 2)
  commissionRate         Decimal?          @map("commission_rate") @db.Decimal(5, 2)
  commissionStatus       CommissionStatus? @map("commission_status")
  commissionPaidAt       DateTime?         @map("commission_paid_at")
  internalNotes          String?           @map("internal_notes")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  documents              LeadDocument[]
  timeline               LeadTimeline[]
  submissionEvents       SubmissionEvent[]
  consentGrants          ConsentGrant[]
  partner                User?             @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  partnerOrg             Partner?          @relation(fields: [partnerOrgId], references: [id], onDelete: SetNull)
  sourcePartnerData      PartnerData?      @relation("LeadSource", fields: [sourcePartnerDataId], references: [id], onDelete: SetNull)

  @@index([partnerId])
  @@index([status])
  @@index([partnerId, status])
  @@index([clientPhone])
  @@index([createdAt(sort: Desc)])
  @@index([partnerOrgId])
  @@index([partnerOrgId, status])
  @@index([sourcePartnerDataId])
  @@map("leads")
}

model LeadDocument {
  id              String                  @id @default(uuid()) @db.Uuid
  leadId          String                  @map("lead_id") @db.Uuid
  type            String
  fileName        String                  @map("file_name")
  fileSize        String?                 @map("file_size")
  fileUrl         String?                 @map("file_url")
  r2ObjectKey     String?                 @map("r2_object_key")
  mimeType        String?                 @map("mime_type")
  uploadedBy      String?                 @map("uploaded_by")
  uploadedAt      DateTime                @default(now()) @map("uploaded_at")
  status          DocumentStatus          @default(pending)
  rejectionReason String?                 @map("rejection_reason")
  lead            Lead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadTokens    DocumentUploadToken[]

  @@index([leadId])
  @@map("lead_documents")
}

model DocumentUploadToken {
  id         String       @id @default(uuid()) @db.Uuid
  token      String       @unique @default(uuid()) @db.Uuid
  documentId String       @map("document_id") @db.Uuid
  leadId     String       @map("lead_id") @db.Uuid
  expiresAt  DateTime     @map("expires_at")
  usedAt     DateTime?    @map("used_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  document   LeadDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([documentId])
  @@map("document_upload_tokens")
}

model StoredClientDocumentUploadToken {
  id              String              @id @default(uuid()) @db.Uuid
  token           String              @unique @default(uuid()) @db.Uuid
  documentId      String              @map("document_id") @db.Uuid
  partnerDataId   String              @map("partner_data_id") @db.Uuid
  expiresAt       DateTime            @map("expires_at")
  usedAt          DateTime?           @map("used_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  document        PartnerDataDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  partnerData     PartnerData         @relation(fields: [partnerDataId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([documentId])
  @@index([partnerDataId])
  @@map("stored_client_document_upload_tokens")
}

model LeadTimeline {
  id        String     @id @default(uuid()) @db.Uuid
  leadId    String     @map("lead_id") @db.Uuid
  status    LeadStatus
  timestamp DateTime   @default(now())
  note      String?
  updatedBy String     @map("updated_by")
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_timeline")
}

model AuditLog {
  id                String         @id @default(uuid()) @db.Uuid
  event             AuditEventType
  userId            String?        @map("user_id") @db.Uuid
  hashedEmail       String?        @map("hashed_email")
  ip                String?
  userAgent         String?        @map("user_agent")
  deviceFingerprint String?        @map("device_fingerprint")
  metadata          Json?
  success           Boolean        @default(true)
  failureReason     String?        @map("failure_reason")
  entityId          String?        @map("entity_id")
  entityType        String?        @map("entity_type")
  severity          String         @default("LOW")
  checksum          String?        @map("checksum")
  createdAt         DateTime       @default(now()) @map("created_at")
  user              User?          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([event, createdAt(sort: Desc)])
  @@index([ip, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([entityId, entityType])
  @@index([severity])
  @@map("audit_logs")
}

model OtpChallenge {
  id                       String    @id @default(uuid()) @db.Uuid
  phone                    String    @unique
  otpHash                  String?   @map("otp_hash")
  otpExpiresAt             DateTime  @map("otp_expires_at")
  verificationToken        String?   @unique @map("verification_token")
  verificationTokenExpires DateTime? @map("verification_token_expires")
  verifiedAt               DateTime? @map("verified_at")
  failedAttempts           Int       @default(0) @map("failed_attempts")
  lockedUntil              DateTime? @map("locked_until")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([phone])
  @@map("otp_challenges")
}

model LenderDocRequirement {
  id              String   @id @default(uuid()) @db.Uuid
  lenderCode      String   @map("lender_code")
  lenderName      String   @map("lender_name")
  loanCode        String   @map("loan_code")
  docId           String   @map("doc_id")
  docName         String   @map("doc_name")
  description     String?
  mandatory       Boolean  @default(true)
  acceptedFormats String[] @map("accepted_formats")
  maxSizeMB       Int      @default(5) @map("max_size_mb")
  sortOrder       Int      @default(0) @map("sort_order")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([lenderCode, loanCode, docId])
  @@index([lenderCode])
  @@index([lenderCode, loanCode])
  @@map("lender_doc_requirements")
}

model Bank {
  id                String               @id @default(uuid()) @db.Uuid
  name              String
  code              String               @unique
  logo              String?
  status            BankStatus           @default(active)
  supportedLoanTypes String[]            @map("supported_loan_types")
  interestRateMin   Decimal              @map("interest_rate_min") @db.Decimal(5, 2)
  interestRateMax   Decimal              @map("interest_rate_max") @db.Decimal(5, 2)
  processingFee     String               @map("processing_fee")
  maxTenure         Int                  @map("max_tenure")
  minAmount         Decimal              @map("min_amount") @db.Decimal(15, 2)
  maxAmount         Decimal              @map("max_amount") @db.Decimal(15, 2)
  processingTime    String               @map("processing_time")
  isPopular         Boolean              @default(false) @map("is_popular")
  features          String[]
  avgTat            Int                  @map("avg_tat")
  activeLeads       Int                  @default(0) @map("active_leads")
  approvalRate      Int                  @default(0) @map("approval_rate")
  totalDisbursed    String               @default("₹0") @map("total_disbursed")
  contactPerson     String               @map("contact_person")
  contactEmail      String               @map("contact_email")
  contactPhone      String               @map("contact_phone")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  commissionRates   BankCommissionRate[]

  @@index([status])
  @@map("banks")
}

model BankCommissionRate {
  id                String   @id @default(uuid()) @db.Uuid
  bankId            String   @map("bank_id") @db.Uuid
  loanType          String   @map("loan_type")
  partnerCommission Decimal  @map("partner_commission") @db.Decimal(5, 2)
  interestRate      String?  @map("interest_rate")
  maxAmount         Decimal? @map("max_amount") @db.Decimal(15, 2)
  minAmount         Decimal? @map("min_amount") @db.Decimal(15, 2)
  maxTenure         Int?     @map("max_tenure")
  bank              Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@unique([bankId, loanType])
  @@index([bankId])
  @@map("bank_commission_rates")
}

model PartnerData {
  id               String          @id @default(uuid()) @db.Uuid
  partnerId        String          @map("partner_id") @db.Uuid
  partnerOrgId     String          @map("partner_org_id") @db.Uuid
  localStatus      LocalLeadStatus @default(new) @map("local_status")
  notes            String?
  // Client info
  fullName         String          @map("full_name")
  phone            String
  email            String?
  dateOfBirth      String?         @map("date_of_birth")
  gender           String?
  panNumber        String?         @map("pan_number")
  employmentType   String?         @map("employment_type")
  monthlyIncome    Decimal?        @map("monthly_income") @db.Decimal(15, 2)
  companyName      String?         @map("company_name")
  designation      String?
  workExperience   String?         @map("work_experience")
  city             String?
  pincode          String?
  state            String?
  currentAddress   String?         @map("current_address")
  residenceType    String?         @map("residence_type")
  // Loan info
  loanCategory     String?         @map("loan_category")
  loanType         String          @map("loan_type")
  loanAmount       Decimal         @map("loan_amount") @db.Decimal(15, 2)
  tenure           Int?
  loanPurpose      String?         @map("loan_purpose")
  preferredBank    String?         @map("preferred_bank")
  encryptionVersion Int            @default(0) @map("encryption_version")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  documents        PartnerDataDocument[]
  uploadTokens     StoredClientDocumentUploadToken[]
  submittedLeads   Lead[]          @relation("LeadSource")
  consentGrants    ConsentGrant[]
  partner          User            @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  partnerOrg       Partner         @relation(fields: [partnerOrgId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([partnerId, localStatus])
  @@index([createdAt(sort: Desc)])
  @@index([partnerOrgId])
  @@index([partnerOrgId, localStatus])
  @@map("partner_data")
}

model ConsentGrant {
  id                String      @id @default(uuid()) @db.Uuid
  leadId            String      @map("lead_id") @db.Uuid
  partnerDataId     String      @map("partner_data_id") @db.Uuid
  partnerId         String      @map("partner_id") @db.Uuid
  submittedBy       String      @map("submitted_by") @db.Uuid
  grantedTo         String      @map("granted_to")
  grantedAt         DateTime    @default(now()) @map("granted_at")
  expiresAt         DateTime?   @map("expires_at")
  revokedAt         DateTime?   @map("revoked_at")
  submissionContext Json        @map("submission_context")
  createdAt         DateTime    @default(now()) @map("created_at")
  lead              Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  partnerData       PartnerData @relation(fields: [partnerDataId], references: [id], onDelete: Restrict)
  partner           Partner     @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  submittedByUser   User        @relation("ConsentGrantSubmittedBy", fields: [submittedBy], references: [id], onDelete: Restrict)

  @@index([leadId])
  @@index([partnerDataId])
  @@index([partnerId, grantedAt(sort: Desc)])
  @@index([grantedTo, revokedAt])
  @@map("consent_grants")
}

model PartnerDataDocument {
  id              String                           @id @default(uuid()) @db.Uuid
  partnerDataId   String                           @map("partner_data_id") @db.Uuid
  type            String
  displayName     String                           @map("display_name")
  description     String?
  mandatory       Boolean                          @default(true)
  acceptedFormats String[]                         @default(["pdf", "jpg", "png"]) @map("accepted_formats")
  maxSizeMB       Int                              @default(10) @map("max_size_mb")
  sortOrder       Int                              @default(0) @map("sort_order")
  fileName        String                           @default("") @map("file_name")
  fileSize        String?                          @map("file_size")
  fileUrl         String?                          @map("file_url")
  r2ObjectKey     String?                          @map("r2_object_key")
  mimeType        String?                          @map("mime_type")
  uploadedBy      String?                          @map("uploaded_by")
  uploadedAt      DateTime                         @default(now()) @map("uploaded_at")
  status          DocumentStatus                   @default(pending)
  rejectionReason String?                          @map("rejection_reason")
  partnerData     PartnerData                      @relation(fields: [partnerDataId], references: [id], onDelete: Cascade)
  uploadTokens    StoredClientDocumentUploadToken[]

  @@index([partnerDataId])
  @@map("partner_data_documents")
}

enum LocalLeadStatus {
  new
  contacted
  docs_pending
  docs_collected
  processing
  approved
  rejected
  closed
}

enum PartnerOrgStatus {
  active
  suspended
  deactivated
}

enum PartnerUserRole {
  admin
  agent
  viewer
}

enum BankStatus {
  active
  inactive
}

enum UserRole {
  super_admin
  admin
  manager
  agent
  viewer
  partner
}

enum PartnerType {
  freelancer
  used_car_dealer
  property_dealer
  builder
  sub_dsa
}

enum OnboardingStatus {
  pending
  approved
  rejected
}

enum KycStatus {
  pending
  verified
  rejected
}

enum LeadStatus {
  draft
  submitted
  docs_pending
  docs_uploaded
  docs_collected
  bank_processing
  bank_logged
  approved
  disbursed
  rejected
}

enum EmploymentType {
  salaried
  self_employed
  business_owner
  professional
}

enum DocumentStatus {
  pending
  uploaded
  verified
  rejected
}

enum CommissionStatus {
  pending
  processing
  paid
}

enum AuditEventType {
  // Auth
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  REGISTER
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  PASSWORD_CHANGE
  OTP_SENT
  OTP_VERIFIED
  OTP_SEND_FAILED
  ACCOUNT_LOCKED
  TOKEN_REFRESH
  SUSPICIOUS_ACTIVITY

  // Lead lifecycle
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_STATUS_CHANGED
  LEAD_DELETED
  LEAD_ASSIGNED

  // Documents
  DOCUMENT_UPLOADED
  DOCUMENT_VIEWED
  DOCUMENT_DOWNLOADED
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
  DOCUMENT_DELETED

  // Partners
  PARTNER_UPDATED
  PARTNER_APPROVED
  PARTNER_SUSPENDED
  PARTNER_KYC_UPDATED

  // Financials
  COMMISSION_CALCULATED
  COMMISSION_PAID
  COMMISSION_RATE_CHANGED

  // Consent & Data Rights
  CONSENT_GIVEN
  CONSENT_WITHDRAWN
  DATA_DELETION_REQUEST

  // Admin
  ADMIN_ROLE_CHANGED
  ADMIN_USER_CREATED
  ADMIN_USER_DELETED
  BULK_EXPORT
  PII_ACCESS
  BANK_UPDATED
  BANK_STATUS_CHANGED

  // Multi-tenant partner
  PARTNER_ORG_CREATED
  PARTNER_USER_ADDED
  PARTNER_USER_REMOVED
  LEAD_SUBMITTED_TO_GPS
